# Copia este archivo a .env y cambia los valores

# === MariaDB central ===
DB_ROOT_PASSWORD=cambia_este_root_password
PASSBOLT_DB_USER=passbolt
PASSBOLT_DB_PASSWORD=cambia_passbolt_db_password
DASHBOARD_DB_USER=dashboard
DASHBOARD_DB_PASSWORD=cambia_dashboard_db_password

# Usuario READ-ONLY que la app unificadora usa para hacer cross-queries
# entre passbolt + dashboard + checkmk + mkmonitor (solo SELECT).
UNIFIED_READER_PASSWORD=cambia_unified_reader_password

# === Passbolt ===
PASSBOLT_DOMAIN=passbolt.local

# === Checkmk ===
CMK_SITE_ID=monitor
CMK_PASSWORD=cambia_password_admin_checkmk
# Despues de iniciar checkmk, crea el usuario "automation" en la UI
# y pega aqui su secret para que el dashboard pueda consultar la API
CMK_AUTOMATION_SECRET=cambia_automation_secret

# === DB espejo ===
# Cada cuantas horas db-sync replica db-central -> db-mirror. Default 1.
SYNC_INTERVAL_HOURS=1

# === Dashboard custom ===
DASHBOARD_SECRET_KEY=cambia_esto_por_una_clave_aleatoria_larga
